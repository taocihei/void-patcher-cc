{
  "id": "js-plugin-load-failed-telemetry-off",
  "description": "Stub `FOK()` \u2014 `tengu_plugin_load_failed` event (plugin error categorization sent to Anthropic on every plugin parse/install failure).",
  "type": "js_replace",
  "validate_js": true,
  "patches": [
    {
      "search_regex": "function ([A-Za-z_$][\\w$]*)\\(H,\\$\\)\\{for\\(let q of H\\)\\{let\\{name:K,marketplace:_\\}=([A-Za-z_$][\\w$]*)\\(q\\.source\\)",
      "replace": "function \\1(H,$){return;for(let q of H){let{name:K,marketplace:_}=\\2(q.source)",
      "applied_marker": "(H,$){return;for(let q of H){let{name:K,marketplace:_}=",
      "description": "Error telemetry on plugin loads leaks plugin names and error categories. Silence.",
      "required": false,
      "count": 0
    }
  ],
  "scan_signatures": true,
  "anchor_strings": [
    "marketplace:",
    "for(let q of H)"
  ],
  "version_last_tested": "2.1.114"
}
