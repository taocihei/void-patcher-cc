{
  "id": "js-hardfail-flag-disable",
  "description": "Neutralize the `--hard-fail` CLI flag so process does not exit on first subagent error.",
  "type": "js_replace",
  "validate_js": true,
  "patches": [
    {
      "search_regex": "[A-Za-z_$][\\w$]*\\(\\);[A-Za-z_$][\\w$]*\\$\\(\\);[A-Za-z_$][\\w$]*\\(\\);[A-Za-z_$][\\w$]*\\$\\(\\);[A-Za-z_$][\\w$]*\\$\\(\\);[A-Za-z_$][\\w$]*\\(\\);[A-Za-z_$][\\w$]*\\$\\(\\);\\$[A-Za-z_$][\\w$]*\\$=\\[\\];[A-Za-z_$][\\w$]*=\\[\\];[A-Za-z_$][\\w$]*=[A-Za-z_$][\\w$]*\\(\\(\\)=>\\{return\\ process\\.argv\\.includes\\(\"\\-\\-hard\\-fail\"\\)\\}\\)\\}\\);function\\ [A-Za-z_$][\\w$]*\\([A-Za-z_$][\\w$]*\\)\\{[A-Za-z_$][\\w$]*\\ \\$=\\[\\],[A-Za-z_$][\\w$]*=!1;async\\ func",
