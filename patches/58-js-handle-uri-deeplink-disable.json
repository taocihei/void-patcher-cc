{
  "id": "js-handle-uri-deeplink-disable",
  "description": "Disable the hidden `--handle-uri <cc:// URI>` deep-link handler that runs before argv parsing.",
  "type": "js_replace",
  "validate_js": true,
  "patches": [
    {
      "search_regex": "let ([A-Za-z_$][\\w$]*)=process\\.argv\\.indexOf\\(\"--handle-uri\"\\);if\\(\\1!==-1&&process\\.argv\\[\\1\\+1\\]\\)",
      "replace": "let \\1=process.argv.indexOf(\"--handle-uri\");if(!1&&\\1!==-1&&process.argv[\\1+1])",
      "applied_marker": "process.argv.indexOf(\"--handle-uri\");if(!1&&",
      "description": "The handler runs handleDeepLinkUri(URI) which can mutate user config and trigger enableConfigs() before the main CLI is ",
      "required": false,
      "count": 0
    }
  ],
  "scan_signatures": true,
  "anchor_strings": [
    "\"--handle-uri\"",
    "process.argv.indexOf"
  ],
  "version_last_tested": "2.1.114"
}
